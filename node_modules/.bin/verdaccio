#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/felipemadureira/Área de trabalho/monorepo/node_modules/.pnpm/verdaccio@6.7.2_typanion@3.14.0/node_modules/verdaccio/node_modules:/home/felipemadureira/Área de trabalho/monorepo/node_modules/.pnpm/verdaccio@6.7.2_typanion@3.14.0/node_modules:/home/felipemadureira/Área de trabalho/monorepo/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/felipemadureira/Área de trabalho/monorepo/node_modules/.pnpm/verdaccio@6.7.2_typanion@3.14.0/node_modules/verdaccio/node_modules:/home/felipemadureira/Área de trabalho/monorepo/node_modules/.pnpm/verdaccio@6.7.2_typanion@3.14.0/node_modules:/home/felipemadureira/Área de trabalho/monorepo/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../verdaccio/bin/verdaccio" "$@"
else
  exec node  "$basedir/../verdaccio/bin/verdaccio" "$@"
fi
